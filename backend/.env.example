NODE_ENV=development
PORT=3000
IBMS_DB_URI=mongodb://127.0.0.1:27017/ibms
JWT_SECRET=replace-with-a-long-random-secret
IBMS_INTEGRATION_TOKEN=
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
ALLOW_VERCEL_PREVIEW_ORIGINS=true
VERCEL_ORIGIN_SUFFIX=.vercel.app
CLINIC_NAME=IBMS Clinic
ENABLE_CRON=true
LOG_LEVEL=info

# Optional HRMS database authentication (read-only user lookup)
HRMS_AUTH_ENABLED=false
HRMS_DB_URI=
HRMS_USER_COLLECTION=usertable
HRMS_LOGIN_FIELD=email
HRMS_IDENTIFIER_FIELDS=email,username,accountId,employeeId,staffId
HRMS_PASSWORD_FIELD=password
HRMS_ROLE_FIELD=role
HRMS_STATUS_FIELD=status
HRMS_NAME_FIELD=name
HRMS_EMAIL_FIELD=email
HRMS_ID_FIELD=_id
HRMS_ACTIVE_VALUES=active,enabled,true,1
HRMS_OWNER_ROLE_VALUES=owner,admin,administrator,superadmin
HRMS_STAFF_ROLE_VALUES=staff,employee,user
HRMS_PASSWORD_ALGORITHM=bcrypt
HRMS_LOGIN_CASE_INSENSITIVE=true
HRMS_REQUIRE_STATUS=false

# Optional PARMS API integration (used for patient lookup, pending balances, and sync-later)
PARMS_API_BASE_URL=
PARMS_API_TOKEN=
PARMS_STRICT_PATIENT_LOOKUP=false
PARMS_PATIENT_SEARCH_PATH=/api/v1/integrations/ibms/patients/search
PARMS_PATIENT_DETAILS_PATH=/api/v1/integrations/ibms/patients/{patientId}
PARMS_PATIENT_BALANCES_PATH=/api/v1/integrations/ibms/patients/{patientId}/pending-balances
PARMS_TRANSACTION_SYNC_PATH=/api/v1/billing/ibms/sync
PARMS_SYNC_CURRENCY=PHP
PARMS_IBMS_TOKEN=
PARMS_SYNC_SIGNING_SECRET=
PARMS_SYNC_RETRY_404=false
PARMS_SYNC_WORKER_ENABLED=true
PARMS_SYNC_WORKER_INTERVAL_MS=15000
