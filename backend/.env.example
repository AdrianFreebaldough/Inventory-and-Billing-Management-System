NODE_ENV=development
PORT=3000
IBMS_DB_URI=mongodb://127.0.0.1:27017/ibms
JWT_SECRET=replace-with-a-long-random-secret
IBMS_INTEGRATION_TOKEN=
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CLINIC_NAME=IBMS Clinic
ENABLE_CRON=true
LOG_LEVEL=info

# Optional PARMS API integration (used for patient lookup, pending balances, and sync-later)
PARMS_API_BASE_URL=
PARMS_API_TOKEN=
PARMS_STRICT_PATIENT_LOOKUP=false
PARMS_PATIENT_SEARCH_PATH=/api/v1/integrations/ibms/patients/search
PARMS_PATIENT_DETAILS_PATH=/api/v1/integrations/ibms/patients/{patientId}
PARMS_PATIENT_BALANCES_PATH=/api/v1/integrations/ibms/patients/{patientId}/pending-balances
PARMS_TRANSACTION_SYNC_PATH=/api/v1/billing/ibms/sync
PARMS_SYNC_CURRENCY=PHP
PARMS_IBMS_TOKEN=
PARMS_SYNC_SIGNING_SECRET=
PARMS_SYNC_WORKER_ENABLED=true
PARMS_SYNC_WORKER_INTERVAL_MS=15000
