{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "routes": [
    {
      "src": "/",
      "dest": "/HTML/loginPage/loginPage.html"
    },
    {
      "src": "/api/(.*)",
      "dest": "https://ibms-backend.vercel.app/api/$1"
    },
    {
      "handle": "filesystem"
    }
  ]
}
